includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    # This is a package: config/ here is the publishable stub, not the app
    # config directory the rule guards, so env() calls in it are correct.
    noEnvCallsOutsideOfConfig: false
